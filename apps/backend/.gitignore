# Dependencies
/node_modules
/.pnpm-store

# Environment files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# Build artifacts
/build
/dist
/out
/.cache
/.parcel-cache
/.next # Next.js
/.nuxt # Nuxt.js
/.svelte-kit # Sveltekit
/.vitepress/dist # Vitepress
/.serverless # Serverless
/.firebase # Firebase

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS and Editor files
.DS_Store # macOS
.vscode # VS Code directory (optional, only ignore if not sharing workspace settings)
*.tgz # Compressed tarball files
.npm # npm cache

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
